FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y \
    libgtk-3-0 libnotify4 libnss3 libxss1 libsecret-1-0 \
    libgbm1 libasound2 libatspi2.0-0 libx11-xcb1 \
    libxcb-dri3-0 libdrm2 libgbm-dev libxkbcommon0 \
    libcups2 libdbus-1-3 libexpat1 libxcomposite1 \
    libxdamage1 libxrandr2 libxfixes3 libxext6 \
    libxi6 libxtst6 ca-certificates \
    gnome-keyring xvfb \
    curl jq && \
    rm -rf /var/lib/apt/lists/*

COPY scripts/docker-smoke-test.sh /docker-smoke-test.sh
RUN chmod +x /docker-smoke-test.sh

ENTRYPOINT ["/docker-smoke-test.sh"]
